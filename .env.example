# Supabase (clés publiables — OK dans le code frontend)
VITE_SUPABASE_URL=https://votre-projet.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGci...votre_cle_anon
VITE_SUPABASE_PROJECT_ID=votre_project_id

