# ─────────────────────────────────────────────────────────────────────────────
# Formetoialia — Variables d'environnement
# Copier ce fichier en .env.local pour le développement local.
# NE JAMAIS committer .env.local ou .env avec de vraies valeurs.
# ─────────────────────────────────────────────────────────────────────────────

# Supabase (clés publiables — OK dans le code frontend)
VITE_SUPABASE_URL=https://votre-projet.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGci...votre_cle_anon
VITE_SUPABASE_PROJECT_ID=votre_project_id

# Stripe (clé publiable — OK dans le code frontend)
# VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Sentry (DSN publique — OK dans le code frontend)
# VITE_SENTRY_DSN=https://xxx@o123.ingest.sentry.io/456

# Version de l'app (injectée par CI)
# VITE_APP_VERSION=1.0.0

# OpenClaw runtime (dev uniquement)
VITE_OPENCLAW_ENABLED=false

# Feature flags (optionnel — voir src/config/features.ts)
# VITE_FF_ADMIN_DASHBOARD=false
# VITE_FF_PALANTIR_MODE=false
# VITE_FF_OPENCLAW_RUNTIME=false
# VITE_FF_MONTHLY_REPORT_AUTO=false
# VITE_FF_PUBLIC_LIVE_STATS=false
# VITE_FF_VOICE_MODE=true

# ─────────────────────────────────────────────────────────────────────────────
# SECRETS (côté serveur uniquement — Edge Functions via Supabase Vault)
# Ne pas mettre ces valeurs ici. Les configurer dans :
# Lovable Cloud → Settings → Secrets
# ─────────────────────────────────────────────────────────────────────────────
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_59_TTC=price_...
# OPENROUTER_API_KEY=sk-or-...
# RESEND_API_KEY=re_...
