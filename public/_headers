/*
  Lovable / Cloudflare Pages security headers
  Applies to all routes on the deployed app.

  CSP Strategy:
  - Phase 1 (CURRENT): Content-Security-Policy-Report-Only
    → Reports violations without breaking the app
    → Monitor /admin/control-room for 7 days before enforcing
  - Phase 2 (TODO): Rename to Content-Security-Policy once reports are clean

  Supabase project: xpzvbsfrwnabnwwfsnnc
  Report endpoint:  https://xpzvbsfrwnabnwwfsnnc.supabase.co/functions/v1/csp-report
*/

/*
  ─── CSP directives breakdown ───────────────────────────────────────────────

  default-src 'self'
    → All resources default to same-origin only

  script-src 'self' 'unsafe-inline' 'unsafe-eval'
    → 'unsafe-inline' required for Vite dev + React HMR
    → 'unsafe-eval' required for some bundled libs (e.g. DOMPurify)
    → cdn.gpteng.co: Lovable platform preview script

  style-src 'self' 'unsafe-inline'
    → Tailwind/styled-components inject inline styles at runtime

  font-src 'self' data:
    → data: URIs for base64-embedded fonts (Tailwind / shadcn)

  img-src 'self' data: blob: https:
    → blob: for canvas captures, user avatars, PDF previews
    → https: for og:image, org logos stored in Supabase storage

  connect-src
    → *.supabase.co  : all Supabase APIs (REST, Auth, Storage, Realtime, Edge Functions)
    → wss://*.supabase.co : Supabase Realtime websocket
    → openrouter.ai  : AI completions (proxied via edge function, but kept for CSP)
    → storage.googleapis.com : og:image and uploaded assets
    → fonts.googleapis.com / fonts.gstatic.com : Google Fonts

  media-src 'self' blob:
    → blob: for Web Speech API TTS audio + DashScope CosyVoice audio playback
    → Required for the KITT visualizer voice engine

  worker-src blob:
    → Required for Web Speech API in some browsers (Chrome creates a worker)

  frame-ancestors 'none'
    → Prevents clickjacking — equivalent to X-Frame-Options: DENY

  report-uri
    → Reports violations to our edge function (stored in csp_reports table)
    → Visible in /admin/control-room
*/

/*
  NOTE: Lovable Cloud deployments use _headers file for Cloudflare Pages/CDN headers.
  Some headers (HSTS) are only effective via HTTP response headers, not meta tags.
*/

https://genie-ai-mastery.lovable.app/*
  # ── Phase 1: Report-Only CSP (monitor violations before enforcing) ──────────
  Content-Security-Policy-Report-Only: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.gpteng.co; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' data: https://fonts.gstatic.com; img-src 'self' data: blob: https:; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://openrouter.ai https://api.dashscope.aliyuncs.com https://storage.googleapis.com https://fonts.googleapis.com https://fonts.gstatic.com; media-src 'self' blob:; worker-src blob:; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'; report-uri https://xpzvbsfrwnabnwwfsnnc.supabase.co/functions/v1/csp-report

  # ── Security hardening headers ───────────────────────────────────────────────
  # HSTS: force HTTPS for 1 year, include subdomains, preload-ready
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

  # Prevent MIME-type sniffing attacks
  X-Content-Type-Options: nosniff

  # Clickjacking protection (belt-and-suspenders with CSP frame-ancestors)
  X-Frame-Options: DENY

  # Referrer: send origin only on cross-origin requests (no path leakage)
  Referrer-Policy: strict-origin-when-cross-origin

  # Permissions Policy: lock down powerful APIs to minimum needed
  # microphone=(self)  → Web Speech API + KITT voice
  # speaker-selection=(self) → TTS playback
  # Everything else denied
  Permissions-Policy: accelerometer=(), ambient-light-sensor=(), autoplay=(self), camera=(), display-capture=(), document-domain=(), encrypted-media=(), fullscreen=(self), geolocation=(), gyroscope=(), magnetometer=(), microphone=(self), midi=(), payment=(), picture-in-picture=(), publickey-credentials-get=(), screen-wake-lock=(), speaker-selection=(self), usb=(), xr-spatial-tracking=()

  # Prevent cross-origin info leakage via performance timing
  Cross-Origin-Embedder-Policy: unsafe-none
  Cross-Origin-Opener-Policy: same-origin-allow-popups
  Cross-Origin-Resource-Policy: cross-origin

  # Cache control for HTML pages (always revalidate)
  Cache-Control: no-store

/*.js
  Cache-Control: public, max-age=31536000, immutable

/*.css
  Cache-Control: public, max-age=31536000, immutable

/*.woff2
  Cache-Control: public, max-age=31536000, immutable

/assets/*
  Cache-Control: public, max-age=31536000, immutable
